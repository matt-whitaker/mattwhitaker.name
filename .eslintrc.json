{
  "env": {
    "browser": true,
    "es6": true
  },
  "extends": [
    "google",
    "plugin:jsdoc/recommended"
  ],
  "parserOptions": {
    "ecmaFeatures": {
      "jsx": true
    },
    "ecmaVersion": 2018,
    "sourceType": "module"
  },
  "parser": "babel-eslint",
  "plugins": [
    "react",
    "jsdoc"
  ],
  "rules": {
    "indent": [2, 2],
    "max-len": [2, { "code": 120 }],
    "object-curly-spacing": [2, "always"],
    "no-unused-vars": [0],
    "sort-imports": ["error", {
      "memberSyntaxSortOrder": ["none", "all", "multiple", "single"]
    }],
    "valid-jsdoc": [0],
    "jsdoc/require-returns-description": [2],
    "space-before-blocks": [2, "always"],
    "block-spacing": [2, "always"],
    "react/prop-types": [2]
  }
}