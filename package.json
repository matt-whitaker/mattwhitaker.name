    "@babel/preset-react": "^7.7.4",
    "acorn": "^6.4.0",
    "autobind-decorator": "^2.4.0",
    "babel-eslint": "^10.0.3",
    "babel-loader": "^8.0.6",
    "config": "^3.2.4",
    "copy-webpack-plugin": "^5.1.1",
    "create-file-webpack": "^1.0.2",
    "css-loader": "^2.1.1",
    "dotenv": "^4.0.0",
    "eslint": "^6.7.2",
