  "description": "my personal profile site",
  "main": "index.js",
  "scripts": {
    "build": "npm run clean && webpack --config build/config/webpack.config.prod.js",
    "build:dev": "npm run clean && webpack --config build/config/webpack.config.dev.js",
    "dev": "npm run clean && webpack-dev-server --watch --config build/config/webpack.config.dev.js",
    "eslint": "eslint src/**/*.js src/**/*.jsx build/**/*.js",
    "clean": "rm -rf lib",
    "stylelint": "stylelint src/**/*.less",
    "test": "npm run stylelint && npm run eslint",
    "update": "node ./build/bin/generateManifest.js && git add *manifest.json"
  },
  "author": "Matt Whitaker <mattwhitaker.name@gmail.com>",
  "license": "ISC",
